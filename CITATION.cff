license: BSD-2-Clause
repository-code: "https://github.com/marwaalrammal/gaussian-tools"
keywords:
  - gaussian
  - computational-chemistry
  - quantum-chemistry
  - python
  - geometry-optimization
  - td-dft
  - vibrational-modes
  - normal-mode-analysis
